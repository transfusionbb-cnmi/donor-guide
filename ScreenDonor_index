<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ระบบสืบค้นเกณฑ์การรับบริจาคโลหิต 2569</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;600&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Sarabun', sans-serif; background-color: #f4f7f9; color: #2d3436; }
        .nav-header { background: #1e3799; color: white; padding: 25px 15px; text-align: center; border-bottom: 5px solid #4a69bd; }
        .search-box { border-radius: 30px; border: 2px solid #1e3799; padding: 12px 25px; margin-top: -25px; box-shadow: 0 4px 15px rgba(0,0,0,0.1); }
        
        .result-card { border: none; border-radius: 15px; margin-bottom: 20px; box-shadow: 0 4px 6px rgba(0,0,0,0.05); overflow: hidden; background: white; transition: 0.3s; }
        .result-card:hover { transform: translateY(-3px); box-shadow: 0 8px 15px rgba(0,0,0,0.1); }
        
        .card-header-custom { background: #f8faff; padding: 15px; border-bottom: 1px solid #edf2f7; }
        .badge-cat { font-size: 0.75rem; background: #4a69bd; color: white; padding: 4px 10px; border-radius: 5px; margin-bottom: 5px; display: inline-block; }
        
        .criteria-section { background: #fffcf0; padding: 15px; border-radius: 10px; margin: 10px 0; border: 1px dashed #f1c40f; }
        .script-section-th { border-left: 4px solid #27ae60; background: #fafffa; padding: 12px; margin-top: 10px; }
        .script-section-en { border-left: 4px solid #2980b9; background: #f0f7ff; padding: 12px; margin-top: 10px; font-style: italic; }
        .label { font-weight: 600; color: #1e3799; font-size: 0.85rem; text-transform: uppercase; margin-bottom: 3px; }
        
        #loading { padding: 50px; }
    </style>
</head>
<body>

<div class="nav-header">
    <h4 class="mb-0 text-white">ระบบสืบค้น เกณฑ์การรับบริจาคโลหิต</h4>
    <p class="small mb-0 opacity-75">โรงพยาบาลรามาธิบดีจักรีนฤบดินทร์</p>
</div>

<div class="container mt-0 pb-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <input type="text" id="searchInput" class="form-control search-box" placeholder="🔍 ค้นหา (เช่น ความดัน, ยา, อายุ, ต่างชาติ...)">
            
            <div id="loading" class="text-center">
                <div class="spinner-border text-primary" role="status"></div>
                <p class="mt-2 text-muted">กำลังดึงข้อมูลจากคลังเลือด...</p>
            </div>

            <div id="results" class="mt-4"></div>
        </div>
    </div>
</div>

<script>
    let rawData = [];
    
    // 🚩 ก๊อปปี้ลิงก์ Web App URL จาก Google มาวางตรงนี้แทนที่ข้อความข้างล่างนะครับ
    const GAS_URL = 'https://script.google.com/macros/s/AKfycbxhfP1zqL5k_IBo4vDpRQpVAuoha2QFMFCi7RGu9M2Cl0Nq0vWrWPhS86z2FQjvbbuR/exec'; 

    // 1. ดึงข้อมูลจาก Google Sheets ทันทีที่เปิดเว็บ
    window.onload = () => {
        if (GAS_URL.includes('ใส่_WEB_APP_URL')) {
            document.getElementById('loading').innerHTML = '<p class="text-danger">อย่าลืมใส่ GAS_URL ในโค้ดนะครับ!</p>';
            return;
        }

        fetch(GAS_URL)
            .then(res => res.json())
            .then(data => {
                rawData = data;
                document.getElementById('loading').style.display = 'none';
                render(data); // แสดงข้อมูลทั้งหมดก่อนในตอนแรก
            })
            .catch(err => {
                console.error('Error:', err);
                document.getElementById('loading').innerText = 'เกิดข้อผิดพลาดในการดึงข้อมูล กรุณาลองใหม่';
            });
    };

    // 2. ระบบค้นหา Real-time
    document.getElementById('searchInput').addEventListener('input', function(e) {
        const keyword = e.target.value.toLowerCase();
        const filtered = rawData.filter(item => 
            String(item['คำที่ใช้ค้นหา']).toLowerCase().includes(keyword) || 
            String(item['หัวข้อ']).toLowerCase().includes(keyword)
        );
        render(filtered);
    });

    // 3. ฟังก์ชันสร้าง Card ข้อมูล
    function render(data) {
        const container = document.getElementById('results');
        if (data.length === 0) {
            container.innerHTML = '<div class="text-center p-5 text-muted">ไม่พบข้อมูลที่ตรงกับคำค้นหา</div>';
            return;
        }

        container.innerHTML = data.map(item => `
            <div class="card result-card">
                <div class="card-header-custom">
                    <span class="badge-cat">${item['หมวดหมู่'] || 'ทั่วไป'}</span>
                    <h5 class="mb-0 text-primary fw-bold">${item['หัวข้อ'] || 'ไม่มีหัวข้อ'}</h5>
                </div>
                <div class="card-body">
                    <div class="criteria-section">
                        <div class="label">📍 เกณฑ์การคัดกรอง</div>
                        <div class="mb-2 text-dark">${item['เกณฑ์การคัดกรอง'] || '-'}</div>
                        <div class="label">⏳ ระยะเวลางดบริจาค</div>
                        <div class="text-danger fw-bold">${item['ระยะเวลางดบริจาค'] || 'ไม่มีกำหนดงด'}</div>
                    </div>

                    <div class="script-section-th">
                        <div class="label text-success">🇹🇭 Script สำหรับเจ้าหน้าที่</div>
                        <div class="small">${item['Script คำอธิบายเพื่อลดแรงปะทะ (เน้นความปลอดภัย)'] || '-'}</div>
                    </div>

                    <div class="script-section-en">
                        <div class="label text-primary">🇺🇸 English Script</div>
                        <div class="small">${item['Script (English)'] || '-'}</div>
                    </div>
                </div>
            </div>
        `).join('');
    }
</script>

</body>
</html>
